@module kirino.debug.compute.vec3f
@gl_version 430

@export
int put(uint header, vec3 data)
{
    uint index = KirinoDebug_allocSafe(header, KIRINO_DEBUG_MAX_VEC3F_RECORD);

    if (!KirinoDebug_validUint(index)) return -1;
    if (!KirinoDebug_writeVec3fRecordMeta(index, data, header)) return -2;

    return int(index);
}